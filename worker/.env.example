# Worker daemon env file — install to /etc/tradingagents-worker.env
# with mode 0600, owned by root.

# ── Cloudflare API ──────────────────────────────────────────
CF_API_BASE=https://tradingagents-api.your-subdomain.workers.dev
CF_INTERNAL_TOKEN=change-me-must-match-the-API-worker-secret

# ── R2 ───────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=r2-access-key
R2_SECRET_ACCESS_KEY=r2-secret-key
R2_BUCKET=tradingagents-reports

# ── Worker identity ─────────────────────────────────────────
WORKER_ID=vps-1
POLL_INTERVAL_SECONDS=3
LOG_LEVEL=INFO

# ── LLM provider keys (needed by TradingAgents itself) ─────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
FINNHUB_API_KEY=
